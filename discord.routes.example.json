{
  "discord": {
    "guildId": "YOUR_DEFAULT_DISCORD_SERVER_ID",
    "bots": [
      {
        "agentId": "example-team-a-facilitator",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_A_FACILITATOR"
      },
      {
        "agentId": "example-team-a-specialist",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_A_SPECIALIST"
      },
      {
        "agentId": "example-team-a-closer",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_A_CLOSER"
      },
      {
        "agentId": "example-team-b-facilitator",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_B_FACILITATOR"
      },
      {
        "agentId": "example-team-b-specialist",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_B_SPECIALIST"
      },
      {
        "agentId": "example-team-b-closer",
        "tokenEnvVar": "DISCORD_TOKEN_TEAM_B_CLOSER"
      }
    ],
    "channels": [
      {
        "channelId": "YOUR_TEAM_A_CHANNEL_ID",
        "teamId": "example-team-a",
        "mode": "meeting-room",
        "ingressAgentId": "example-team-a-facilitator"
      },
      {
        "guildId": "YOUR_TEAM_B_DISCORD_SERVER_ID",
        "channelId": "YOUR_TEAM_B_CHANNEL_ID",
        "teamId": "example-team-b",
        "mode": "meeting-room",
        "ingressAgentId": "example-team-b-facilitator"
      }
    ],
    "aliases": {
      "example-team-a": {
        "@facilitator": "example-team-a-facilitator",
        "@specialist": "example-team-a-specialist",
        "@closer": "example-team-a-closer"
      },
      "example-team-b": {
        "@facilitator": "example-team-b-facilitator",
        "@specialist": "example-team-b-specialist",
        "@closer": "example-team-b-closer"
      }
    },
    "responsePolicy": {
      "agentProvider": "codex-acp",
      "ignoreUnknownChannels": true,
      "ignoreBotMessages": true,
      "reactWhileProcessing": true,
      "typingWhileProcessing": true,
      "typingRefreshMs": 8000,
      "progressNotices": true,
      "progressNoticeAfterMs": 20000,
      "progressNoticeRepeatMs": 60000,
      "processingTimeoutMs": 600000,
      "perTurnDelayMs": 500,
      "agentThinking": "off",
      "agentTimeoutSec": 45,
      "agentWallTimeout": "90s",
      "presence": {
        "status": "online",
        "activityType": "watching",
        "activityName": "team prompts"
      }
    }
  }
}
