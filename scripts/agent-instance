#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "usage: $0 <instance-id> <agent args...>" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

instance="$1"
shift

container_prefix="${AGENT_CONTAINER_PREFIX:-openclaw}"
container="${container_prefix}-${instance}"
run_id="agent-cli-$$-$RANDOM"
outfile="/tmp/${run_id}.out"
statusfile="/tmp/${run_id}.status"
wall_timeout="${AGENT_WALL_TIMEOUT:-${OPENCLAW_WALL_TIMEOUT:-}}"
prompt_style="${AGENT_INSTANCE_PROMPT_STYLE:-${OPENCLAW_INSTANCE_PROMPT_STYLE:-passthrough}}"

container_has_legacy_cli() {
  docker exec "$container" sh -lc 'command -v openclaw >/dev/null 2>&1'
}

run_legacy_container() {
  docker_cmd=(docker exec "$container" sh -lc '
    outfile="$1"
    statusfile="$2"
    shift 2
    openclaw "$@" >"$outfile" 2>&1
    printf "%s" "$?" >"$statusfile"
  ' sh "$outfile" "$statusfile" "$@")

  if [[ -n "$wall_timeout" ]]; then
    if ! timeout --foreground "${wall_timeout}" "${docker_cmd[@]}"; then
      status=$?
      if [[ $status -eq 124 ]]; then
        docker exec "$container" sh -lc 'pkill -f "openclaw agent --local" >/dev/null 2>&1 || true' >/dev/null 2>&1 || true
        printf 'timed out after %ss\n' "$wall_timeout" >&2
      fi
      docker exec "$container" sh -lc 'cat "$1"' sh "$outfile" 2>/dev/null || true
      docker exec "$container" sh -lc 'rm -f "$1" "$2"' sh "$outfile" "$statusfile" >/dev/null 2>&1 || true
      exit "$status"
    fi
  else
    "${docker_cmd[@]}"
  fi

  status="$(docker exec "$container" sh -lc 'cat "$1"' sh "$statusfile" 2>/dev/null || printf '1')"
  docker exec "$container" sh -lc 'cat "$1"' sh "$outfile" 2>/dev/null || true
  docker exec "$container" sh -lc 'rm -f "$1" "$2"' sh "$outfile" "$statusfile" >/dev/null 2>&1 || true
  exit "$status"
}

run_codex_acp_fallback() {
  local mode="$1"
  shift

  local message=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --message)
        message="${2:-}"
        shift 2
        ;;
      *)
        shift
        ;;
    esac
  done

  if [[ -z "$message" ]]; then
    echo "missing --message for provider fallback" >&2
    return 1
  fi

  node "$ROOT/scripts/codex-acp-agent-runner.mjs" "$instance" "$mode" "$message"
}

if container_has_legacy_cli; then
  run_legacy_container "$@"
fi

mode="passthrough"
if [[ "$prompt_style" == "direct" ]]; then
  mode="direct"
fi

if [[ -n "$wall_timeout" ]]; then
  if ! timeout --foreground "${wall_timeout}" run_codex_acp_fallback "$mode" "$@"; then
    status=$?
    if [[ $status -eq 124 ]]; then
      printf 'timed out after %ss\n' "$wall_timeout" >&2
    fi
    exit "$status"
  fi
else
  run_codex_acp_fallback "$mode" "$@"
fi
