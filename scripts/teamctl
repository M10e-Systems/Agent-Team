#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE_FILE="$ROOT/runtime/docker-compose.generated.yml"
INDEX_FILE="$ROOT/runtime/team-index.json"
AGENT_CONTAINER_PREFIX="${AGENT_CONTAINER_PREFIX:-openclaw}"
OPENCLAW_IMAGE="${OPENCLAW_IMAGE:-openclaw:local}"
OPENCLAW_REPO_PATH="${OPENCLAW_REPO_PATH:-$ROOT/../openclaw}"
OPENCLAW_DOCKERFILE="${OPENCLAW_DOCKERFILE:-$OPENCLAW_REPO_PATH/Dockerfile}"

need_runtime() {
  if [[ ! -f "$COMPOSE_FILE" || ! -f "$INDEX_FILE" ]]; then
    echo "runtime not generated; run: $ROOT/scripts/instantiate-openclaw-teams.mjs" >&2
    exit 1
  fi
}

need_index() {
  if [[ ! -f "$INDEX_FILE" ]]; then
    echo "team index not generated; run: $ROOT/scripts/instantiate-openclaw-teams.mjs" >&2
    exit 1
  fi
}

is_team() {
  node -e '
    const idx=require(process.argv[1]);
    process.exit(idx.teams[process.argv[2]] ? 0 : 1);
  ' "$INDEX_FILE" "$1"
}

is_agent() {
  node -e '
    const idx=require(process.argv[1]);
    process.exit(idx.agents[process.argv[2]] ? 0 : 1);
  ' "$INDEX_FILE" "$1"
}

team_agents() {
  node -e '
    const idx=require(process.argv[1]);
    const team=idx.teams[process.argv[2]];
    if (!team) process.exit(2);
    for (const id of team.agentIds) console.log(id);
  ' "$INDEX_FILE" "$1"
}

show_usage() {
  cat <<'EOF'
usage:
  teamctl init
  teamctl build
  teamctl up [team-id]
  teamctl down [team-id]
  teamctl restart [team-id]
  teamctl status [team-id]
  teamctl list
  teamctl ask <agent-id> <message...>
  teamctl room <team-id> <message...>
  teamctl heartbeat <team-id> [prompt...]
  teamctl discord-init
  teamctl discord-validate [routes-file]
  teamctl discord-run [routes-file]
  teamctl discord-inject <channel-id|team-id> <message...>
  teamctl discord-provider-doctor [routes-file]
  teamctl logs <agent-id>
  teamctl shell <agent-id>
  teamctl ps <team-id>
  teamctl path <agent-id>
  teamctl dashboard <agent-id>

notes:
  - team ids: example-team-a, example-team-b
  - agent ids: example-team-a-facilitator, example-team-a-architect, example-team-a-growth, example-team-b-facilitator, example-team-b-editor, example-team-b-maker
  - discord-* commands use the provider-selected runtime and do not require agent containers.
  - dashboard is informational in the current model; these instances do not run a long-lived gateway by default.
  - build uses OPENCLAW_REPO_PATH/OPENCLAW_DOCKERFILE and tags the image as OPENCLAW_IMAGE (defaults to openclaw:local).
EOF
}

need_openclaw_build_inputs() {
  if [[ ! -d "$OPENCLAW_REPO_PATH" ]]; then
    echo "missing OpenClaw repo: $OPENCLAW_REPO_PATH" >&2
    exit 1
  fi
  if [[ ! -f "$OPENCLAW_DOCKERFILE" ]]; then
    echo "missing Dockerfile: $OPENCLAW_DOCKERFILE" >&2
    exit 1
  fi
}

build_openclaw_image() {
  need_openclaw_build_inputs
  docker build -t "$OPENCLAW_IMAGE" -f "$OPENCLAW_DOCKERFILE" "$OPENCLAW_REPO_PATH"
}

ensure_openclaw_image() {
  if [[ "${TEAMCTL_BUILD_ALWAYS:-0}" == "1" ]]; then
    build_openclaw_image
    return
  fi
  if ! docker image inspect "$OPENCLAW_IMAGE" >/dev/null 2>&1; then
    build_openclaw_image
  fi
}

compose_up_all() {
  ensure_openclaw_image
  docker compose -f "$COMPOSE_FILE" up -d
}

compose_up_team() {
  local team="$1"
  local services=()
  while IFS= read -r agent; do
    services+=("$agent")
  done < <(team_agents "$team")
  ensure_openclaw_image
  docker compose -f "$COMPOSE_FILE" up -d "${services[@]}"
}

compose_down_all() {
  docker compose -f "$COMPOSE_FILE" down
}

compose_down_team() {
  local team="$1"
  local services=()
  while IFS= read -r agent; do
    services+=("$agent")
  done < <(team_agents "$team")

  # docker compose has no "down <service>" equivalent; stop+rm is the closest.
  docker compose -f "$COMPOSE_FILE" stop "${services[@]}" || true
  docker compose -f "$COMPOSE_FILE" rm -f "${services[@]}" || true
}

cmd="${1:-}"
case "$cmd" in
  init)
    "$ROOT/scripts/instantiate-openclaw-teams.mjs"
    ;;
  build)
    build_openclaw_image
    ;;
  up)
    need_runtime
    team="${2:-}"
    if [[ -z "$team" ]]; then
      compose_up_all
      exit 0
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    compose_up_team "$team"
    ;;
  down)
    need_runtime
    team="${2:-}"
    if [[ -z "$team" ]]; then
      compose_down_all
      exit 0
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    compose_down_team "$team"
    ;;
  restart)
    need_runtime
    team="${2:-}"
    if [[ -z "$team" ]]; then
      compose_down_all
      compose_up_all
      exit 0
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    compose_down_team "$team"
    compose_up_team "$team"
    ;;
  status)
    need_runtime
    team="${2:-}"
    if [[ -z "$team" ]]; then
      docker ps --format '{{.Names}}\t{{.Status}}' | rg "${AGENT_CONTAINER_PREFIX}-(example-team-a|example-team-b)" || true
      exit 0
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    "$ROOT/scripts/teamctl" ps "$team"
    ;;
  list)
    need_runtime
    node -e '
      const idx=require(process.argv[1]);
      for (const [teamId, team] of Object.entries(idx.teams)) {
        console.log(`${teamId}: ${team.agentIds.join(", ")}`);
      }
    ' "$INDEX_FILE"
    ;;
  ask)
    need_runtime
    agent="${2:-}"
    shift 2 || true
    if [[ -z "$agent" || $# -eq 0 ]]; then
      show_usage
      exit 1
    fi
    if ! is_agent "$agent"; then
      echo "unknown agent: $agent" >&2
      exit 1
    fi
    AGENT_INSTANCE_PROMPT_STYLE=direct "$ROOT/scripts/agent-instance" "$agent" agent --local --agent main --message "$*"
    ;;
  room)
    need_runtime
    team="${2:-}"
    shift 2 || true
    if [[ -z "$team" || $# -eq 0 ]]; then
      show_usage
      exit 1
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    "$ROOT/scripts/team-room" "$team" "$*"
    ;;
  heartbeat)
    need_runtime
    team="${2:-}"
    shift 2 || true
    if [[ -z "$team" ]]; then
      show_usage
      exit 1
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    "$ROOT/scripts/team-heartbeat" "$team" "$@"
    ;;
  discord-init)
    target="$ROOT/discord.routes.json"
    if [[ -f "$target" ]]; then
      echo "already exists: $target"
      exit 0
    fi
    cp "$ROOT/discord.routes.example.json" "$target"
    echo "created: $target"
    echo "next: fill in your real Discord guild/channel ids, then export DISCORD_BOT_TOKEN and run:"
    echo "  $ROOT/scripts/teamctl discord-validate"
    echo "  $ROOT/scripts/teamctl discord-run"
    ;;
  discord-validate)
    need_index
    routes_file="${2:-$ROOT/discord.routes.json}"
    node "$ROOT/scripts/discord-broker.mjs" validate "$routes_file"
    ;;
  discord-run)
    need_index
    routes_file="${2:-$ROOT/discord.routes.json}"
    node "$ROOT/scripts/discord-broker.mjs" run "$routes_file"
    ;;
  discord-inject)
    need_index
    target="${2:-}"
    shift 2 || true
    if [[ -z "$target" || $# -eq 0 ]]; then
      show_usage
      exit 1
    fi
    node "$ROOT/scripts/discord-broker.mjs" inject "$ROOT/discord.routes.json" "$target" "$*"
    ;;
  discord-provider-doctor)
    need_index
    routes_file="${2:-$ROOT/discord.routes.json}"
    node "$ROOT/scripts/discord-broker.mjs" provider-doctor "$routes_file"
    ;;
  logs)
    need_runtime
    agent="${2:-}"
    if [[ -z "$agent" ]]; then
      show_usage
      exit 1
    fi
    if ! is_agent "$agent"; then
      echo "unknown agent: $agent" >&2
      exit 1
    fi
    docker logs -f "${AGENT_CONTAINER_PREFIX}-$agent"
    ;;
  shell)
    need_runtime
    agent="${2:-}"
    if [[ -z "$agent" ]]; then
      show_usage
      exit 1
    fi
    if ! is_agent "$agent"; then
      echo "unknown agent: $agent" >&2
      exit 1
    fi
    exec docker exec -it "${AGENT_CONTAINER_PREFIX}-$agent" sh
    ;;
  ps)
    need_runtime
    team="${2:-}"
    if [[ -z "$team" ]]; then
      show_usage
      exit 1
    fi
    if ! is_team "$team"; then
      echo "unknown team: $team" >&2
      exit 1
    fi
    while IFS= read -r agent; do
      docker ps --filter "name=${AGENT_CONTAINER_PREFIX}-$agent" --format '{{.Names}}\t{{.Status}}'
    done < <(team_agents "$team")
    ;;
  path)
    need_runtime
    agent="${2:-}"
    if [[ -z "$agent" ]]; then
      show_usage
      exit 1
    fi
    node -e '
      const path=require("path");
      const toolsRoot=process.argv[1];
      const idx=require(process.argv[2]);
      const entry=idx.agents[process.argv[3]];
      if (!entry) process.exit(2);
      console.log(path.isAbsolute(entry.runtimeStateDir) ? entry.runtimeStateDir : path.resolve(toolsRoot, entry.runtimeStateDir));
    ' "$ROOT" "$INDEX_FILE" "$agent"
    ;;
  dashboard)
    need_runtime
    agent="${2:-}"
    if [[ -z "$agent" ]]; then
      show_usage
      exit 1
    fi
    if ! is_agent "$agent"; then
      echo "unknown agent: $agent" >&2
      exit 1
    fi
    cat <<EOF
No dashboard URL is exposed for $agent in the current runtime model.

This is intentional:
- each container is an isolated agent workspace
- turns run via 'docker exec ... agent --local ...'
- no long-lived per-container gateway is bound to a host port

If you want dashboard access later, we can add an alternate gateway-backed mode for selected agents.
EOF
    ;;
  ""|-h|--help|help)
    show_usage
    ;;
  *)
    echo "unknown command: $cmd" >&2
    show_usage
    exit 1
    ;;
esac
